# Computrabajo Bot — Credenciales y Configuración
# Copia este archivo como .env y llena tus datos
# NUNCA subas el .env a GitHub

# ─── Computrabajo ───────────────────────────────
CT_EMAIL=tu_email@gmail.com
CT_PASSWORD=tu_contraseña_aqui

# ─── Gemini API (opcional pero recomendado) ──────
# Obtén una gratis en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_aqui
